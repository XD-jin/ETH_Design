{
  "top_module": "ETH_MAC_TOP",
  "description": "Gigabit Ethernet MAC Controller with AHB Host Interface and RGMII PHY Interface. 1000Mbps Full-Duplex, 2-Channel DMA, IEEE 802.3x Flow Control.",
  "modules": [
    {
      "name": "AHB_SLAVE_IF",
      "type": "bus_interface",
      "layer": "L1",
      "protocol": "AMBA 2.0 AHB Slave",
      "clock_domain": "hclk",
      "ports": [
        {"name": "hclk", "direction": "input", "width": 1, "type": "clock"},
        {"name": "hresetn", "direction": "input", "width": 1, "type": "reset", "active": "low", "async": true},
        {"name": "hsel", "direction": "input", "width": 1, "type": "control"},
        {"name": "haddr", "direction": "input", "width": 13, "type": "address"},
        {"name": "hwrite", "direction": "input", "width": 1, "type": "control"},
        {"name": "hwdata", "direction": "input", "width": 32, "type": "data"},
        {"name": "htrans", "direction": "input", "width": 2, "type": "control"},
        {"name": "hrdata", "direction": "output", "width": 32, "type": "data"},
        {"name": "hready", "direction": "output", "width": 1, "type": "control"},
        {"name": "hresp", "direction": "output", "width": 1, "type": "control"},
        {"name": "reg_wr_en", "direction": "output", "width": 1, "type": "control"},
        {"name": "reg_addr", "direction": "output", "width": 13, "type": "address"},
        {"name": "reg_wr_data", "direction": "output", "width": 32, "type": "data"},
        {"name": "reg_rd_data", "direction": "input", "width": 32, "type": "data"}
      ],
      "description": "CSR register access via AHB Slave. Decodes 8KB address space, outputs register read/write signals to REG_FILE."
    },
    {
      "name": "AHB_MASTER_IF",
      "type": "bus_interface",
      "layer": "L1",
      "protocol": "AMBA 2.0 AHB Master",
      "clock_domain": "hclk",
      "ports": [
        {"name": "hclk", "direction": "input", "width": 1, "type": "clock"},
        {"name": "hresetn", "direction": "input", "width": 1, "type": "reset", "active": "low", "async": true},
        {"name": "dma_req", "direction": "input", "width": 1, "type": "control"},
        {"name": "dma_grant", "direction": "output", "width": 1, "type": "control"},
        {"name": "dma_addr", "direction": "input", "width": 32, "type": "address"},
        {"name": "dma_wdata", "direction": "input", "width": 32, "type": "data"},
        {"name": "dma_rdata", "direction": "output", "width": 32, "type": "data"},
        {"name": "dma_burst_len", "direction": "input", "width": 4, "type": "control"},
        {"name": "dma_write", "direction": "input", "width": 1, "type": "control"},
        {"name": "dma_ready", "direction": "output", "width": 1, "type": "control"},
        {"name": "dma_error", "direction": "output", "width": 1, "type": "control"},
        {"name": "hm_addr_o", "direction": "output", "width": 32, "type": "address"},
        {"name": "hm_write_o", "direction": "output", "width": 1, "type": "control"},
        {"name": "hm_wdata_o", "direction": "output", "width": 32, "type": "data"},
        {"name": "hm_rdata_i", "direction": "input", "width": 32, "type": "data"},
        {"name": "hm_ready_i", "direction": "input", "width": 1, "type": "control"},
        {"name": "hm_resp_i", "direction": "input", "width": 1, "type": "control"}
      ],
      "description": "AHB Master for DMA data transfers. Supports INCR/SINGLE bursts with configurable length, 1KB boundary splitting."
    },
    {
      "name": "REG_FILE",
      "type": "register_file",
      "layer": "L1",
      "clock_domain": "hclk",
      "ports": [
        {"name": "hclk", "direction": "input", "width": 1, "type": "clock"},
        {"name": "hresetn", "direction": "input", "width": 1, "type": "reset", "active": "low", "async": true},
        {"name": "reg_wr_en", "direction": "input", "width": 1, "type": "control"},
        {"name": "reg_addr", "direction": "input", "width": 13, "type": "address"},
        {"name": "reg_wr_data", "direction": "input", "width": 32, "type": "data"},
        {"name": "reg_rd_data", "direction": "output", "width": 32, "type": "data"}
      ],
      "parameters": [
        {"name": "P_SHELL_MODE", "default": 0}
      ],
      "description": "46-register CSR file decoding MAC/MTL/DMA/DMA_CH blocks. Outputs config wires to all sub-modules."
    },
    {
      "name": "DMA_CONTROLLER",
      "type": "control",
      "layer": "L2",
      "clock_domain": "hclk",
      "submodules": ["DMA_TX_CH0", "DMA_TX_CH1", "DMA_RX_CH0", "DMA_RX_CH1", "DMA_ARBITER", "DMA_INTR_CTRL"],
      "ports": [
        {"name": "clk", "direction": "input", "width": 1, "type": "clock"},
        {"name": "rst_n", "direction": "input", "width": 1, "type": "reset", "active": "low", "async": true},
        {"name": "ati_val", "direction": "output", "width": 1, "type": "control"},
        {"name": "ati_rdy", "direction": "input", "width": 1, "type": "control"},
        {"name": "ati_data", "direction": "output", "width": 32, "type": "data"},
        {"name": "ati_sop", "direction": "output", "width": 1, "type": "control"},
        {"name": "ati_eop", "direction": "output", "width": 1, "type": "control"},
        {"name": "ati_queue", "direction": "output", "width": 1, "type": "control"},
        {"name": "ari_val", "direction": "input", "width": 1, "type": "control"},
        {"name": "ari_rdy", "direction": "output", "width": 1, "type": "control"},
        {"name": "ari_data", "direction": "input", "width": 32, "type": "data"},
        {"name": "ari_sop", "direction": "input", "width": 1, "type": "control"},
        {"name": "ari_eop", "direction": "input", "width": 1, "type": "control"},
        {"name": "intr_o", "direction": "output", "width": 1, "type": "interrupt"},
        {"name": "intr_status", "direction": "output", "width": 4, "type": "status"}
      ],
      "description": "2 TX + 2 RX DMA channels with ring descriptor engine, channel arbiter (TX:SP, RX:RR), and interrupt coalescing."
    },
    {
      "name": "MTL_TX",
      "type": "buffer",
      "layer": "L3",
      "clock_domain": "cross (hclk ↔ gmii_tx_clk)",
      "cdc": "async_fifo with Gray-code pointers",
      "ports": [
        {"name": "app_clk", "direction": "input", "width": 1, "type": "clock"},
        {"name": "gmii_tx_clk", "direction": "input", "width": 1, "type": "clock"},
        {"name": "rst_n", "direction": "input", "width": 1, "type": "reset", "active": "low", "async": true},
        {"name": "ati_val", "direction": "input", "width": 1, "type": "control"},
        {"name": "ati_rdy", "direction": "output", "width": 1, "type": "control"},
        {"name": "ati_data", "direction": "input", "width": 32, "type": "data"},
        {"name": "ati_sop", "direction": "input", "width": 1, "type": "control"},
        {"name": "ati_eop", "direction": "input", "width": 1, "type": "control"},
        {"name": "ati_queue", "direction": "input", "width": 1, "type": "control"},
        {"name": "mti_val", "direction": "output", "width": 1, "type": "control"},
        {"name": "mti_rdy", "direction": "input", "width": 1, "type": "control"},
        {"name": "mti_data", "direction": "output", "width": 8, "type": "data"},
        {"name": "mti_sop", "direction": "output", "width": 1, "type": "control"},
        {"name": "mti_eop", "direction": "output", "width": 1, "type": "control"}
      ],
      "parameters": [
        {"name": "P_QUEUE_DEPTH", "default": 4096},
        {"name": "P_NUM_QUEUES", "default": 2},
        {"name": "P_SHELL_MODE", "default": 0}
      ],
      "description": "MTL Transmit Path — 2-queue shared SRAM with async FIFO per queue and Tx Scheduler (SP with anti-starvation)."
    },
    {
      "name": "MTL_RX",
      "type": "buffer",
      "layer": "L3",
      "clock_domain": "cross (gmii_rx_clk ↔ hclk)",
      "cdc": "async_fifo with Gray-code pointers",
      "ports": [
        {"name": "gmii_rx_clk", "direction": "input", "width": 1, "type": "clock"},
        {"name": "app_clk", "direction": "input", "width": 1, "type": "clock"},
        {"name": "rst_n", "direction": "input", "width": 1, "type": "reset", "active": "low", "async": true},
        {"name": "mri_val", "direction": "input", "width": 1, "type": "control"},
        {"name": "mri_rdy", "direction": "output", "width": 1, "type": "control"},
        {"name": "mri_data", "direction": "input", "width": 8, "type": "data"},
        {"name": "mri_sop", "direction": "input", "width": 1, "type": "control"},
        {"name": "mri_eop", "direction": "input", "width": 1, "type": "control"},
        {"name": "ari_val", "direction": "output", "width": 1, "type": "control"},
        {"name": "ari_rdy", "direction": "input", "width": 1, "type": "control"},
        {"name": "ari_data", "direction": "output", "width": 32, "type": "data"},
        {"name": "ari_sop", "direction": "output", "width": 1, "type": "control"},
        {"name": "ari_eop", "direction": "output", "width": 1, "type": "control"},
        {"name": "ari_queue", "direction": "output", "width": 1, "type": "control"}
      ],
      "parameters": [
        {"name": "P_QUEUE_DEPTH", "default": 8192},
        {"name": "P_NUM_QUEUES", "default": 2},
        {"name": "P_SHELL_MODE", "default": 0}
      ],
      "description": "MTL Receive Path — 2-queue shared SRAM with DA-based routing and Rx Scheduler (RR)."
    },
    {
      "name": "MAC_TX",
      "type": "datapath",
      "layer": "L4",
      "clock_domain": "gmii_tx_clk (125MHz)",
      "fsm_states": ["TX_IDLE", "TX_PREAMBLE", "TX_SFD", "TX_DATA", "TX_CRC", "TX_IFG"],
      "ports": [
        {"name": "gmii_tx_clk", "direction": "input", "width": 1, "type": "clock"},
        {"name": "rst_n", "direction": "input", "width": 1, "type": "reset", "active": "low", "async": true},
        {"name": "tx_enable", "direction": "input", "width": 1, "type": "control"},
        {"name": "mti_val", "direction": "input", "width": 1, "type": "control"},
        {"name": "mti_rdy", "direction": "output", "width": 1, "type": "control"},
        {"name": "mti_data", "direction": "input", "width": 8, "type": "data"},
        {"name": "mti_sop", "direction": "input", "width": 1, "type": "control"},
        {"name": "mti_eop", "direction": "input", "width": 1, "type": "control"},
        {"name": "gmii_txd", "direction": "output", "width": 8, "type": "data"},
        {"name": "gmii_tx_en", "direction": "output", "width": 1, "type": "control"},
        {"name": "gmii_tx_er", "direction": "output", "width": 1, "type": "control"},
        {"name": "tx_frame_done", "direction": "output", "width": 1, "type": "status"},
        {"name": "tx_underflow", "direction": "output", "width": 1, "type": "status"},
        {"name": "tx_jabber", "direction": "output", "width": 1, "type": "status"}
      ],
      "parameters": [
        {"name": "P_SHELL_MODE", "default": 0}
      ],
      "description": "MAC TX Pipeline (TBU→TPC→TPE). Inserts Preamble+SFD, computes CRC-32, pads frames <60B, enforces IFG. 3-process FSM."
    },
    {
      "name": "MAC_RX",
      "type": "datapath",
      "layer": "L4",
      "clock_domain": "gmii_rx_clk (125MHz, from PHY)",
      "fsm_states": ["RX_IDLE", "RX_PREAMBLE", "RX_SFD", "RX_DATA", "RX_STATUS"],
      "ports": [
        {"name": "gmii_rx_clk", "direction": "input", "width": 1, "type": "clock"},
        {"name": "rst_n", "direction": "input", "width": 1, "type": "reset", "active": "low", "async": true},
        {"name": "rx_enable", "direction": "input", "width": 1, "type": "control"},
        {"name": "gmii_rxd", "direction": "input", "width": 8, "type": "data"},
        {"name": "gmii_rx_dv", "direction": "input", "width": 1, "type": "control"},
        {"name": "gmii_rx_er", "direction": "input", "width": 1, "type": "control"},
        {"name": "mri_val", "direction": "output", "width": 1, "type": "control"},
        {"name": "mri_rdy", "direction": "input", "width": 1, "type": "control"},
        {"name": "mri_data", "direction": "output", "width": 8, "type": "data"},
        {"name": "mri_sop", "direction": "output", "width": 1, "type": "control"},
        {"name": "mri_eop", "direction": "output", "width": 1, "type": "control"},
        {"name": "rx_da_valid", "direction": "output", "width": 1, "type": "control"},
        {"name": "rx_da", "direction": "output", "width": 48, "type": "data"},
        {"name": "frame_pass", "direction": "input", "width": 1, "type": "control"},
        {"name": "rx_crc_error", "direction": "output", "width": 1, "type": "status"},
        {"name": "rx_recv_error", "direction": "output", "width": 1, "type": "status"},
        {"name": "rx_watchdog_error", "direction": "output", "width": 1, "type": "status"},
        {"name": "rx_frame_done", "direction": "output", "width": 1, "type": "status"},
        {"name": "rx_pause_detected", "direction": "output", "width": 1, "type": "status"}
      ],
      "parameters": [
        {"name": "P_SHELL_MODE", "default": 0}
      ],
      "description": "MAC RX Pipeline (RxMAC→CRC→RPC→RBI). Strips Preamble+SFD, verifies CRC-32, extracts DA/SA/Type, detects Pause frames."
    },
    {
      "name": "CRC32",
      "type": "datapath",
      "layer": "L4",
      "ports": [
        {"name": "clk", "direction": "input", "width": 1, "type": "clock"},
        {"name": "rst_n", "direction": "input", "width": 1, "type": "reset", "active": "low", "async": true},
        {"name": "crc_en", "direction": "input", "width": 1, "type": "control"},
        {"name": "crc_data", "direction": "input", "width": 8, "type": "data"},
        {"name": "crc_eop", "direction": "input", "width": 1, "type": "control"},
        {"name": "crc_result", "direction": "output", "width": 32, "type": "data"},
        {"name": "crc_valid", "direction": "output", "width": 1, "type": "control"}
      ],
      "parameters": [
        {"name": "P_SHELL_MODE", "default": 0}
      ],
      "description": "IEEE 802.3 CRC-32 LFSR (polynomial 0x04C11DB7). Byte-serial feed, 32-bit parallel feedback. TX: generator, RX: checker."
    },
    {
      "name": "ADDR_FILTER",
      "type": "control",
      "layer": "L4",
      "clock_domain": "gmii_rx_clk",
      "ports": [
        {"name": "clk", "direction": "input", "width": 1, "type": "clock"},
        {"name": "rst_n", "direction": "input", "width": 1, "type": "reset", "active": "low", "async": true},
        {"name": "cfg_promiscuous", "direction": "input", "width": 1, "type": "config"},
        {"name": "cfg_pass_all_mcast", "direction": "input", "width": 1, "type": "config"},
        {"name": "cfg_hash_mode", "direction": "input", "width": 1, "type": "config"},
        {"name": "cfg_mac_addr", "direction": "input", "width": 192, "type": "config"},
        {"name": "cfg_hash_table", "direction": "input", "width": 64, "type": "config"},
        {"name": "rx_da_valid", "direction": "input", "width": 1, "type": "control"},
        {"name": "rx_da", "direction": "input", "width": 48, "type": "data"},
        {"name": "frame_pass", "direction": "output", "width": 1, "type": "control"},
        {"name": "hash_hit", "direction": "output", "width": 1, "type": "status"}
      ],
      "parameters": [
        {"name": "P_MAC_ADDR_ENTRIES", "default": 4},
        {"name": "P_HASH_TABLE_WIDTH", "default": 64},
        {"name": "P_SHELL_MODE", "default": 0}
      ],
      "description": "DA filter: 4-entry perfect match (48-bit comparators) + 64-bit hash filter for multicast."
    },
    {
      "name": "FLOW_CONTROL",
      "type": "control",
      "layer": "L4",
      "clock_domain": "gmii_clk",
      "fsm_states": ["FC_IDLE", "FC_PAUSE_SENT", "FC_ZERO_QUANTA"],
      "ports": [
        {"name": "clk", "direction": "input", "width": 1, "type": "clock"},
        {"name": "rst_n", "direction": "input", "width": 1, "type": "reset", "active": "low", "async": true},
        {"name": "tx_fc_enable", "direction": "input", "width": 1, "type": "config"},
        {"name": "rx_fc_enable", "direction": "input", "width": 1, "type": "config"},
        {"name": "tx_pause_request", "direction": "output", "width": 1, "type": "control"},
        {"name": "tx_pause_time_out", "direction": "output", "width": 16, "type": "data"},
        {"name": "pause_tx_stop", "direction": "output", "width": 1, "type": "control"},
        {"name": "rx_pause_detected", "direction": "input", "width": 1, "type": "control"},
        {"name": "rx_pause_time", "direction": "input", "width": 16, "type": "data"}
      ],
      "parameters": [
        {"name": "P_SHELL_MODE", "default": 0}
      ],
      "description": "IEEE 802.3x Flow Control. TX: watermark-triggered Pause generation. RX: Pause timer countdown (512 bit-time units)."
    },
    {
      "name": "RGMII_IF",
      "type": "io_interface",
      "layer": "L4",
      "protocol": "RGMII v2.6",
      "clock_domain": "gmii_tx_clk / gmii_rx_clk",
      "ports": [
        {"name": "gtx_clk", "direction": "input", "width": 1, "type": "clock"},
        {"name": "rx_clk", "direction": "input", "width": 1, "type": "clock"},
        {"name": "rst_n", "direction": "input", "width": 1, "type": "reset", "active": "low", "async": true},
        {"name": "mac_txd", "direction": "input", "width": 8, "type": "data"},
        {"name": "mac_tx_en", "direction": "input", "width": 1, "type": "control"},
        {"name": "mac_tx_er", "direction": "input", "width": 1, "type": "control"},
        {"name": "mac_rxd", "direction": "output", "width": 8, "type": "data"},
        {"name": "mac_rx_dv", "direction": "output", "width": 1, "type": "control"},
        {"name": "mac_rx_er", "direction": "output", "width": 1, "type": "control"},
        {"name": "rgmii_txc", "direction": "output", "width": 1, "type": "clock"},
        {"name": "rgmii_txd", "direction": "output", "width": 4, "type": "data"},
        {"name": "rgmii_tx_ctl", "direction": "output", "width": 1, "type": "control"},
        {"name": "rgmii_rxc", "direction": "input", "width": 1, "type": "clock"},
        {"name": "rgmii_rxd", "direction": "input", "width": 4, "type": "data"},
        {"name": "rgmii_rx_ctl", "direction": "input", "width": 1, "type": "control"}
      ],
      "parameters": [
        {"name": "P_SHELL_MODE", "default": 0}
      ],
      "description": "RGMII v2.6 4-bit DDR adapter. TX: 8-bit SDR→4-bit DDR. RX: 4-bit DDR→8-bit SDR. FPGA: needs IDDR/ODDR inference.",
      "fpga_note": "dual-edge sampling requires IDDR/ODDR primitives for synthesis"
    }
  ],
  "registers": [
    {"name": "MAC_Configuration", "offset": "0x0000", "block": "EQOS_MAC", "attr": "RW", "reset": "0x0000_0000", "v10": true},
    {"name": "MAC_Packet_Filter", "offset": "0x0008", "block": "EQOS_MAC", "attr": "RW", "reset": "0x0000_0000", "v10": true},
    {"name": "MAC_Watchdog_Timeout", "offset": "0x000C", "block": "EQOS_MAC", "attr": "RW", "reset": "0x0000_0000", "v10": true},
    {"name": "MAC_Hash_Table_Reg0", "offset": "0x0010", "block": "EQOS_MAC", "attr": "RW", "reset": "0x0000_0000", "v10": true},
    {"name": "MAC_Hash_Table_Reg1", "offset": "0x0014", "block": "EQOS_MAC", "attr": "RW", "reset": "0x0000_0000", "v10": true},
    {"name": "MAC_Q0_Tx_Flow_Ctrl", "offset": "0x0070", "block": "EQOS_MAC", "attr": "RW", "reset": "0x0000_0000", "v10": true},
    {"name": "MAC_Q1_Tx_Flow_Ctrl", "offset": "0x0074", "block": "EQOS_MAC", "attr": "RW", "reset": "0x0000_0000", "v10": true},
    {"name": "MAC_Rx_Flow_Ctrl", "offset": "0x0090", "block": "EQOS_MAC", "attr": "RW", "reset": "0x0000_0000", "v10": true},
    {"name": "MAC_Interrupt_Status", "offset": "0x00B0", "block": "EQOS_MAC", "attr": "RC/W1C", "reset": "0x0000_0000", "v10": true},
    {"name": "MAC_Interrupt_Enable", "offset": "0x00B4", "block": "EQOS_MAC", "attr": "RW", "reset": "0x0000_0000", "v10": true},
    {"name": "MAC_Rx_Tx_Status", "offset": "0x00B8", "block": "EQOS_MAC", "attr": "RO", "reset": "0x0000_0000", "v10": true},
    {"name": "MAC_Version", "offset": "0x0110", "block": "EQOS_MAC", "attr": "RO", "reset": "0x0000_0100", "v10": true},
    {"name": "MAC_Address0_High", "offset": "0x0300", "block": "EQOS_MAC", "attr": "RW", "reset": "0x0000_0000", "v10": true},
    {"name": "MAC_Address0_Low", "offset": "0x0304", "block": "EQOS_MAC", "attr": "RW", "reset": "0x0000_0000", "v10": true},
    {"name": "MAC_Address1_High", "offset": "0x0308", "block": "EQOS_MAC", "attr": "RW", "reset": "0x0000_0000", "v10": true},
    {"name": "MAC_Address1_Low", "offset": "0x030C", "block": "EQOS_MAC", "attr": "RW", "reset": "0x0000_0000", "v10": true},
    {"name": "MAC_Address2_High", "offset": "0x0310", "block": "EQOS_MAC", "attr": "RW", "reset": "0x0000_0000", "v10": true},
    {"name": "MAC_Address2_Low", "offset": "0x0314", "block": "EQOS_MAC", "attr": "RW", "reset": "0x0000_0000", "v10": true},
    {"name": "MAC_Address3_High", "offset": "0x0318", "block": "EQOS_MAC", "attr": "RW", "reset": "0x0000_0000", "v10": true},
    {"name": "MAC_Address3_Low", "offset": "0x031C", "block": "EQOS_MAC", "attr": "RW", "reset": "0x0000_0000", "v10": true},
    {"name": "MTL_Operation_Mode", "offset": "0x0C00", "block": "EQOS_MTL", "attr": "RW", "reset": "0x0000_0000", "v10": true},
    {"name": "MTL_Interrupt_Status", "offset": "0x0C20", "block": "EQOS_MTL", "attr": "RO", "reset": "0x0000_0000", "v10": true},
    {"name": "MTL_RxQ_DMA_Map0", "offset": "0x0C30", "block": "EQOS_MTL", "attr": "RW", "reset": "0x0000_0000", "v10": true},
    {"name": "DMA_Mode", "offset": "0x1000", "block": "EQOS_DMA", "attr": "RW", "reset": "0x0000_0000", "v10": true},
    {"name": "DMA_SysBus_Mode", "offset": "0x1004", "block": "EQOS_DMA", "attr": "RW", "reset": "0x0100_0000", "v10": true},
