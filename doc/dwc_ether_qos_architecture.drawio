    <!-- Clock info bar -->
    <mxCell id="clk_bar" value="&lt;b&gt;Clocks:&lt;/b&gt;  csr_clk  |  app_clk  |  gmii_tx_clk (125MHz)  |  gmii_rx_clk (125MHz)  |  mdio_clk (≤2.5MHz)    &lt;b&gt;CDC:&lt;/b&gt; all GMII↔core via async FIFO w/ Gray-code" style="rounded=0;shadow=0;gradient=none;fillColor=#FFF5E6;strokeColor=#6C757D;strokeWidth=1;whiteSpace=wrap;html=1;fontColor=#000000;fontName=Arial;fontSize=8;" vertex="1" parent="1">
      <mxGeometry x="420" y="595" width="1060" height="20" as="geometry"/>
    </mxCell>

    <!-- ====== DATA FLOW ANNOTATIONS ====== -->
    <mxCell id="ann_tx" value="TX:  Memory → DMA Read → MTL TxQ → TxArb → MAC Tx → PHY I/F → PHY" style="text;fontColor=#2A9D8F;fontName=Arial;fontSize=9;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="430" y="400" width="600" height="16" as="geometry"/>
    </mxCell>
    <mxCell id="ann_rx" value="RX:  PHY → PHY I/F → MAC Rx → MTL RxQ → RxArb → DMA Write → Memory" style="text;fontColor=#2A9D8F;fontName=Arial;fontSize=9;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="430" y="418" width="600" height="16" as="geometry"/>
    </mxCell>
    <mxCell id="ann_ctl" value="CTL: CPU → CSR Slave (AHB/APB/AXI) → MAC / MTL / DMA register R/W" style="text;fontColor=#E63946;fontName=Arial;fontSize=9;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="430" y="436" width="600" height="16" as="geometry"/>
    </mxCell>

    <!-- ====== EDGES ====== -->

    <!-- Bus → CSR (control) -->
    <mxCell id="e1" value="" style="orthogonal=1;strokeColor=#E63946;strokeWidth=1;endArrow=block;arrowColor=#E63946;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="190" y="274" as="sourcePoint"/>
        <mxPoint x="280" y="274" as="targetPoint"/>
        <Array as="points">
          <mxPoint x="280" y="274"/>
          <mxPoint x="280" y="390"/>
          <mxPoint x="500" y="390"/>
          <mxPoint x="500" y="140"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Bus → DMA Tx (data) -->
    <mxCell id="e2" value="" style="orthogonal=1;strokeColor=#2A9D8F;strokeWidth=2;endArrow=block;arrowColor=#2A9D8F;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="190" y="274" as="sourcePoint"/>
        <mxPoint x="620" y="102" as="targetPoint"/>
        <Array as="points">
          <mxPoint x="350" y="274"/>
          <mxPoint x="350" y="102"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Bus → DMA Rx (data) -->
    <mxCell id="e3" value="" style="orthogonal=1;strokeColor=#2A9D8F;strokeWidth=2;endArrow=block;arrowColor=#2A9D8F;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="190" y="274" as="sourcePoint"/>
        <mxPoint x="620" y="217" as="targetPoint"/>
        <Array as="points">
          <mxPoint x="350" y="274"/>
          <mxPoint x="350" y="217"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- DMA Tx → MTL TxQ (forward data) -->
    <mxCell id="e4" value="" style="orthogonal=1;strokeColor=#2A9D8F;strokeWidth=2;endArrow=block;arrowColor=#2A9D8F;" edge="1" parent="1" source="dma_tx" target="mtl_txq">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="l4" value="ATI" style="text;fontColor=#2A9D8F;fontName=Arial;fontSize=8;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="740" y="88" width="28" height="14" as="geometry"/>
    </mxCell>

    <!-- MTL RxQ → DMA Rx (backward data) — route BELOW both blocks -->
    <mxCell id="e5" value="" style="orthogonal=1;strokeColor=#2A9D8F;strokeWidth=2;endArrow=block;arrowColor=#2A9D8F;" edge="1" parent="1" source="mtl_rxq" target="dma_rx">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="760" y="245"/>
          <mxPoint x="760" y="270"/>
          <mxPoint x="690" y="270"/>
          <mxPoint x="690" y="245"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="l5" value="ARI" style="text;fontColor=#2A9D8F;fontName=Arial;fontSize=8;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="748" y="258" width="24" height="14" as="geometry"/>
    </mxCell>

    <!-- MTL TxQ → MAC TX (forward) -->
    <mxCell id="e6" value="" style="orthogonal=1;strokeColor=#2A9D8F;strokeWidth=2;endArrow=block;arrowColor=#2A9D8F;" edge="1" parent="1" source="mtl_txq" target="mac_tx">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="l6" value="MTI" style="text;fontColor=#2A9D8F;fontName=Arial;fontSize=8;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="920" y="88" width="28" height="14" as="geometry"/>
    </mxCell>

    <!-- MAC RX → MTL RxQ (backward) — route BELOW -->
    <mxCell id="e7" value="" style="orthogonal=1;strokeColor=#2A9D8F;strokeWidth=2;endArrow=block;arrowColor=#2A9D8F;" edge="1" parent="1" source="mac_rx" target="mtl_rxq">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="940" y="245"/>
          <mxPoint x="940" y="270"/>
          <mxPoint x="870" y="270"/>
          <mxPoint x="870" y="245"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="l7" value="MRI" style="text;fontColor=#2A9D8F;fontName=Arial;fontSize=8;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="928" y="258" width="24" height="14" as="geometry"/>
    </mxCell>

    <!-- MAC TX → PHY MUX (forward) -->
    <mxCell id="e8" value="" style="orthogonal=1;strokeColor=#F4A261;strokeWidth=2;endArrow=block;arrowColor=#F4A261;" edge="1" parent="1" source="mac_tx" target="phy_mux">
      <mxGeometry relative="1" as="geometry"/>
